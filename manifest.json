{
  "manifest_version": 3,
  "name": "Time Grasp - Take Control of Your Time",
  "version": "0.1.1",
  "description": "See how much usable time you really have left before bed.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "public/time-grasp-16.png",
    "32": "public/time-grasp-32.png",
    "48": "public/time-grasp-48.png",
    "128": "public/time-grasp-128.png"
  },
  "action": {
    "default_title": "Time Grasp",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "public/time-grasp-16.png",
      "32": "public/time-grasp-32.png"
    }
  }
}
